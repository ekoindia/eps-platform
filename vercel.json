{
	"redirects": [
		{
			"source": "/products/ppi-levin-api",
			"destination": "/products/ppi-api",
			"permanent": true
		},
		{
			"source": "/products/ppi-digikhata-api",
			"destination": "/products/ppi-api",
			"permanent": true
		},
		{
			"source": "/docs/dmt-sender-ekyc",
			"destination": "/docs/dmt-fino-sender-ekyc",
			"permanent": true
		},
		{
			"source": "/docs/dmt-validate-ekyc-otp",
			"destination": "/docs/dmt-fino-validate-ekyc-otp",
			"permanent": true
		},
		{
			"source": "/docs/aadhaar-dmt-fino-ekyc",
			"destination": "/docs/dmt-fino-sender-ekyc",
			"permanent": true
		},
		{
			"source": "/docs/aadhaar-dmt-fino-verify-otp",
			"destination": "/docs/dmt-fino-validate-ekyc-otp",
			"permanent": true
		},
		{
			"source": "/docs/quickstart",
			"destination": "/docs",
			"permanent": true
		},
		{
			"source": "/recipe/dmt-send-money",
			"destination": "/recipe/dmt-fino-send-money",
			"permanent": true
		},
		{
			"source": "/recipe/dmt-send-money.md",
			"destination": "/recipe/dmt-fino-send-money.md",
			"permanent": true
		}
	],
	"rewrites": [
		{
			"source": "/llms-full.txt",
			"destination": "/index.md"
		},
		{
			"source": "/((?!assets/).*)",
			"destination": "/__spa-fallback.html"
		}
	],
	"headers": [
		{
			"source": "/assets/(.*)",
			"headers": [
				{
					"key": "Cache-Control",
					"value": "public, max-age=31536000, immutable"
				}
			]
		},
		{
			"source": "/(.*)\\.md",
			"headers": [
				{ "key": "Content-Type", "value": "text/markdown; charset=utf-8" },
				{
					"key": "Cache-Control",
					"value": "public, max-age=300, must-revalidate"
				}
			]
		},
		{
			"source": "/llms.txt",
			"headers": [
				{ "key": "Content-Type", "value": "text/plain; charset=utf-8" },
				{
					"key": "Cache-Control",
					"value": "public, max-age=300, must-revalidate"
				}
			]
		}
	]
}
