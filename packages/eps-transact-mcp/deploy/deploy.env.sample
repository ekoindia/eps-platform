# Copy to deploy.env on the host. The poller rewrites EPS_TRANSACT_MCP_IMAGE
# in-place on each deploy (other lines are preserved). Never commit deploy.env.
EPS_TRANSACT_MCP_IMAGE=ghcr.io/ekoindia/eps-transact-mcp:prod

# Optional: POSTed alerts on deploy/rollback/HOLD. Leave unset to only log.
# POLLER_ALERT_WEBHOOK=https://hooks.example.com/…
