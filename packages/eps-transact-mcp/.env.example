# Live UAT smoke credentials (src/uat-smoke.test.ts). Copy to .env (gitignored)
# and fill in — the smoke self-skips while any of the first three is empty.
# Inline shell vars take precedence over this file.
EPS_UAT_DEVELOPER_KEY=
EPS_UAT_ACCESS_KEY=
EPS_UAT_INITIATOR_ID=
# Optional
EPS_UAT_USER_CODE=
