{
	"name": "@ekoindia/eps-backend",
	"version": "0.1.0",
	"private": true,
	"description": "EPS backend BFF — developer + admin auth, profile, agentic endpoints.",
	"license": "MIT",
	"type": "module",
	"repository": {
		"type": "git",
		"url": "https://github.com/ekoindia/eps-platform.git",
		"directory": "packages/eps-backend"
	},
	"bin": {
		"eps-backend": "dist/index.js"
	},
	"files": [
		"dist"
	],
	"scripts": {
		"dev": "tsx watch --env-file-if-exists=.env src/index.ts",
		"build": "tsup",
		"start": "node dist/index.js",
		"test": "vitest run",
		"test:watch": "vitest",
		"typecheck": "tsc --noEmit",
		"test:poller": "bash deploy/poller/test/run.sh"
	},
	"dependencies": {
		"@hono/node-server": "^1.0.0",
		"hono": "^4.0.0",
		"jose": "^5.0.0",
		"redis": "^4.7.1"
	},
	"devDependencies": {
		"@types/node": "^22.20.0",
		"tsup": "^8.5.1",
		"tsx": "^4.22.4",
		"typescript": "^5.9.3",
		"vitest": "^3.2.6"
	},
	"engines": {
		"node": "22.x"
	}
}
