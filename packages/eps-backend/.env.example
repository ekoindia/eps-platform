# Service
PORT=8787
JWT_SECRET=change-me-to-a-32+char-random-string
ACCESS_TTL_SEC=900
REFRESH_TTL_SEC=2592000
COOKIE_SECURE=true
CORS_ORIGINS=https://eps.eko.in

# Eko backend (SimpliBank) — internal API
SIMPLIBANK_API_HOST=
SIMPLIBANK_API_PORT=
SIMPLIBANK_API_PATH=
SIMPLIBANK_API_SCHEME=https
# Set true only for a trusted private-network upstream that is HTTP-only
SIMPLIBANK_ALLOW_INSECURE_HTTP=false
EKO_DEVELOPER_KEY=
EKO_INITIATOR_ID=1234567891
EKO_USER_CODE=99029899
EKO_DEFAULT_ORG_ID=1

# GitHub OAuth (admin)
# Create an OAuth App at https://github.com/settings/developers (OAuth Apps →
# New OAuth App; org-owned: Org → Settings → Developer settings → OAuth Apps).
# Copy the Client ID; "Generate a new client secret" for the secret (shown once).
# The App's "Authorization callback URL" must EXACTLY match GITHUB_CALLBACK_URL.
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GITHUB_CALLBACK_URL=https://eps.eko.in/api/auth/admin/github/callback
# Local dev (via the Vite :8080 proxy — see README "Local dev (GitHub OAuth)"):
# GITHUB_CALLBACK_URL=http://localhost:8080/api/auth/admin/github/callback
GITHUB_REPO=ekoindia/eps-platform
# Branch the admin console commits doc edits to (PR base); deploy promotes editBase -> prodBase.
GITHUB_EDIT_BASE=dev
GITHUB_PROD_BASE=main

# Zoho CRM (optional lead enrichment)
ZOHO_ENABLED=false
ZOHO_BASE_URL=
ZOHO_ACCESS_TOKEN=
