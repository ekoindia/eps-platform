{
	"name": "@ekoindia/eps-context-mcp",
	"version": "0.1.0",
	"description": "Local MCP server giving AI coding agents context for Eko Platform Services (EPS) APIs.",
	"license": "MIT",
	"type": "module",
	"repository": {
		"type": "git",
		"url": "https://github.com/ekoindia/eps-platform.git",
		"directory": "packages/eps-context-mcp"
	},
	"publishConfig": {
		"access": "public"
	},
	"bin": {
		"eps-context-mcp": "dist/index.js"
	},
	"files": [
		"dist",
		"data"
	],
	"scripts": {
		"bake": "node scripts/bake-bundle.mjs",
		"build": "tsup",
		"test": "vitest run",
		"typecheck": "tsc --noEmit",
		"prepublishOnly": "npm run bake && npm run build"
	},
	"dependencies": {
		"@modelcontextprotocol/sdk": "^1.29.0",
		"hono": "^4.0.0",
		"zod": "^4.0.0"
	},
	"devDependencies": {
		"tsup": "^8.0.0",
		"typescript": "^5.8.3",
		"vitest": "^3.2.4"
	},
	"engines": {
		"node": ">=18"
	}
}
