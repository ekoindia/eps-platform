# ---------------------------------------------------------------------------
# Local dev env for the /docs "Try it" console (Scalar API-client modal).
#
# Copy to `.env.local` (gitignored) and fill with your own UAT/sandbox creds:
#   cp .env.example .env.local
#
# The two creds below ONLY prefill the Scalar auth panel during `vite dev`
# (gated by import.meta.env.DEV). They are NEVER read or bundled in production
# builds. At runtime the access_key is used purely for in-browser HMAC signing
# (src/lib/docs/eko-signing.ts via the beforeRequest plugin); it is stripped
# before the request is sent and never leaves the browser — only the computed
# secret-key signature goes out.
#
# Leave blank to type creds manually in the modal instead.
# ---------------------------------------------------------------------------

# Eko UAT/sandbox developer_key (static API key issued after signup)
VITE_EPS_UAT_DEVELOPER_KEY=

# Eko UAT/sandbox access_key (used for local HMAC signing only — keep secret)
VITE_EPS_UAT_ACCESS_KEY=

# ---------------------------------------------------------------------------
# CORS proxy for the Try-it modal. The sandbox blocks direct browser requests
# (CORS), so Scalar routes them through a proxy. Defaults to Scalar's hosted
# proxy. Point it at a self-hosted proxy, or BLANK this line to disable the
# proxy entirely (requests go direct and will likely fail CORS).
# ---------------------------------------------------------------------------
VITE_SCALAR_PROXY_URL=https://proxy.scalar.com

# EPS Console auth UI
# Show the user Log in / Console entry points (header + footer). Keep false in prod until tested.
VITE_SHOW_USER_LOGIN=false

# EPS Transactional MCP marketing
# Split the "AI" nav into "Build with AI" + "For AI agents" and prerender/index
# the /agents page. Keep false until eps-transact-mcp is live in production and
# smoke-tested. Off = single "AI Agents" link; /agents stays an unindexed preview.
VITE_SHOW_TRANSACT_MCP=false

# Optional override for the eps-backend base URL. Defaults to same-origin "/api".
# VITE_EPS_BACKEND_URL=/api

# Dev-only: where the Vite /api proxy forwards (defaults to http://localhost:8787).
# VITE_DEV_BACKEND_ORIGIN=http://localhost:8787
