# ---------------------------------------------------------------------------
# Local dev env for the /docs "Try it" console.
#
# Copy to `.env.local` (gitignored) and fill with your own UAT/sandbox creds:
#   cp .env.example .env.local
#
# These ONLY prefill the Try-It credential fields during `vite dev`
# (gated by import.meta.env.DEV in src/components/docs/TryItPanel.tsx).
# They are NEVER read or bundled in production builds.
#
# At runtime the access_key is used purely for in-browser HMAC signing
# (src/lib/docs/eko-signing.ts); it never leaves the browser, only the
# computed secret-key signature is sent to the sandbox.
#
# Leave blank to type creds manually in the UI instead.
# ---------------------------------------------------------------------------

# Eko UAT/sandbox developer_key (static API key issued after signup)
VITE_EPS_UAT_DEVELOPER_KEY=

# Eko UAT/sandbox access_key (used for local HMAC signing only — keep secret)
VITE_EPS_UAT_ACCESS_KEY=
